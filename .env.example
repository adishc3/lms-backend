# Database Configuration (Required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Security (Required)
SECRET_KEY=your-secret-key-change-me-in-production

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
CORS_ALLOWED_ORIGIN_REGEX=^https://.*\.vercel\.app$

# Token Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SMTP Configuration (Optional)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=False
SMTP_USE_SSL=False
EMAIL_FROM=noreply@example.com
EMAIL_ENABLED=False

# AI Configuration (Required if AI features are used)
AI_ENABLED=True
AI_PROVIDER_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent
AI_API_KEY=your-google-gemini-api-key
AI_DEFAULT_MODEL=gemini-2.5-flash-lite
AI_TEMPERATURE=0.5
AI_TIMEOUT_SECONDS=30

# File Upload Configuration
UPLOAD_FOLDER=static/uploads
UPLOAD_MAX_SIZE=20000000

# Security & Performance
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
FORCE_HTTPS=False
GZIP_MIN_SIZE=1000

# Rate Limiting
REDIS_URL=
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Cloudinary Configuration (Optional - for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
